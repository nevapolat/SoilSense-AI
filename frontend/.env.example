# Copy to `.env` and set values locally. Never commit real API keys.

#

# Netlify / static hosts: add the same VITE_* variables under Site settings →

# Environment variables, then redeploy. Vite bakes them in at build time.



# Anthropic Claude — Haiku only (all AI features)

# VITE_ANTHROPIC_API_KEY=

# Optional: separate key for Haiku-only billing/projects; if unset, VITE_ANTHROPIC_API_KEY is used.

# VITE_ANTHROPIC_HAIKU_API_KEY=



# Claude model id (default in code: claude-haiku-4-5-20251001)

# VITE_CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001



# Optional: different Haiku snapshot for soil health advisor only (defaults to VITE_CLAUDE_HAIKU_MODEL)

# VITE_CLAUDE_SOIL_ADVICE_MODEL=claude-haiku-4-5-20251001



# Anthropic usage telemetry: call counts + cumulative tokens in localStorage (`soilsense.anthropicUsage.v1`). On by default in `vite` dev; for production builds set:

# VITE_ANTHROPIC_USAGE_TELEMETRY=true



# --- Supabase (optional cloud auth + user_profiles sync) ---

# VITE_SUPABASE_URL=

# VITE_SUPABASE_ANON_KEY=

# Password reset email redirects here; must match an entry in Supabase → Authentication → URL Configuration → Redirect URLs.

# Example dev: http://localhost:5173/

# VITE_SUPABASE_AUTH_REDIRECT_URL=

