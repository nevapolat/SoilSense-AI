# Copy to `.env` and set values locally. Never commit real API keys.

# LLM backend: `gemini` (default) or `claude`
# VITE_LLM_PROVIDER=gemini

# Google Gemini (when VITE_LLM_PROVIDER=gemini)
# VITE_GEMINI_API_KEY=

# Anthropic Claude (when VITE_LLM_PROVIDER=claude)
# VITE_ANTHROPIC_API_KEY=

# Primary Claude model (code default: claude-sonnet-4-20250514)
# VITE_CLAUDE_MODEL=claude-sonnet-4-20250514

# Haiku (only when VITE_LLM_PROVIDER=claude):
# If VITE_CLAUDE_HAIKU_FEATURES is unset or empty, the app routes these to Haiku by default:
#   knowledgeHub, smartAlert, dailyTasks, soilAdvice, compostRecipe, soilVitality,
#   locationIntel, farmDailyInsight, apiKeyTest
# Primary model (VITE_CLAUDE_MODEL) is used for plant scan (vision) and anything not listed.
# VITE_CLAUDE_HAIKU_MODEL=claude-haiku-4-5-20251001

# Disable Haiku routing (use primary model for all features):
# VITE_CLAUDE_HAIKU_FEATURES=none

# Or set an explicit list (comma-separated, case-insensitive):
# VITE_CLAUDE_HAIKU_FEATURES=knowledgeHub,smartAlert,dailyTasks,soilAdvice,compostRecipe
